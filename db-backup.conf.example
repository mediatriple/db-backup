BACKUP_DIR="backups"
RETENTION_DAYS="7"
# Aynı anda kaç veritabanı yedeği alınacağını belirler.
MAX_PARALLEL_JOBS="10"
# Yedek .sql.gz dosyalarının tutulacağı ana klasör.
# Script içinde host_port_user bazlı alt klasörler açılır.
DUMP_DIR="backups/dumps"
# Log dosyalarının tutulacağı ana klasör.
# Script içinde host_port_user bazlı alt klasörler açılır.
LOG_DIR="backups/logs"
# Kompakt modda kaç backup'ta bir progress satırı basılacağını belirler.
CONSOLE_PROGRESS_EVERY="5"

# Format:
# "backup_name|host|port|db_name|user|pass|excluded_table1,excluded_table2|mysql_extra_options"
# mysql_extra_options opsiyoneldir ve virgulle ayrilir.
# backup_name opsiyoneldir; verilirse dump/log klasoru bu isimle acilir.
# Ornek: wp_hosting|127.0.0.1|3306|*|backup_user|backup_pass||--ssl-mode=DISABLED
DATABASES=(
  # Örnek: Kullanıcının erişebildiği tüm DB'leri otomatik yedeklemek için
  # DB_NAME alanına "*" yazabilirsiniz.
  # "my_named_backup|127.0.0.1|3306|*|backup_user|backup_pass||"

)
